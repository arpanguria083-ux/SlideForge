{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SlideForge Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "SlideForge-AI/SlideForge-AI",
      "port": 3000
    },
    {
      "name": "SlideForge Backend (FastAPI/uvicorn)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "SlideForge-AI/backend",
      "port": 8000
    }
  ]
}
